# ROS 2 / colcon
build/
install/
log/
ros/build/
ros/install/
ros/log/

# Python
__pycache__/
*.pyc
.venv/

# IDE
.idea/

# Local tooling venv (URDF validation without full ROS install)
.venv/

# Firecrawl / local scrape cache (optional)
.firecrawl/

# Rust target dirs (local `cargo` without CMake / editor checks)
ros/src/driver/target/
crates/target/
target/

# ts-rs default export dir (bindings land in link/src/lib/types/ via TS_RS_EXPORT_DIR)
crates/cortex/bindings/

# rust-embed copy target. `crates/cortex/build.rs` regenerates this from
# `link/dist/` on every cargo build (or writes a stub if dist/ is missing),
# so committing it just produces enormous review-noise diffs and per-machine
# working-tree churn. Real shipping happens via `release.yaml`, which builds
# `link/` first and embeds the result into the Pi binary.
crates/cortex/static/

# Node / Vite (link frontend)
link/node_modules/
link/dist/
link/.vite/
link/*.tsbuildinfo

# cortex local state (paths + token file naming; binary is `cortex`)
**/.cortex/
**/.rudyd/

# Local dev terminal captures (e.g. from `npm run smoke -- --spawn`)
terminal-*.log
