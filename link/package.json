{
  "name": "link",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Rudy operator console (frontend). Served by the `cortex` daemon via Tailscale-only HTTPS.",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.5.1"
  },
  "scripts": {
    "dev": "npm run bake:urdf && vite",
    "gen:routes": "node scripts/gen-routetree.mjs",
    "bake:urdf": "node scripts/bake-urdf.mjs",
    "build": "npm run bake:urdf && npm run gen:routes && tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "npm run gen:routes && tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node scripts/smoke-contract.mjs",
    "gen:types": "cd ../crates && cargo test -p cortex export_bindings"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-router": "^1.95.0",
    "cbor-x": "^1.6.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.3.0",
    "tailwind-merge": "^2.6.1",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "uplot": "^1.6.32",
    "urdf-loader": "^0.12.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/router-devtools": "^1.95.0",
    "@tanstack/router-generator": "^1.166.32",
    "@tanstack/router-plugin": "^1.95.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4.1.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.15.0",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^4.1.4"
  }
}
