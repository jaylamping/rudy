# Copy to `.env.local` and edit. `.env.local` is git-ignored.
#
# URL of the rudydae daemon to proxy /api/* (and serve as origin) during
# `npm run dev`. Defaults to http://127.0.0.1:8443 when unset.
#
# Point this at the Pi over Tailscale to develop the UI against real
# hardware without running rudydae locally:
#
#   VITE_RUDYD_URL=https://rudy.your-tailnet.ts.net:8443
#
# Note: WebTransport (telemetry firehose) is negotiated separately via
# `GET /api/config` and connects directly from the browser to the URL the
# server advertises — it does not go through the Vite proxy.
VITE_RUDYD_URL=http://127.0.0.1:8443
