<?xml version="1.0"?>
<launch>
  <!-- Headless smoke test: no RViz / GUI (CI + Pi5). -->
  <arg name="use_sim_time" default="false"/>
  <!--
    Only invoke <set_use_sim_time> when the user opts in. The action's
    post-condition check in launch_ros<=0.26.x asserts the resulting parameter
    is truthy, which raises "Failed to set use_sim_time parameter" whenever
    the requested value is false (see ros2/launch_ros#487, fix in #488/#491).
    Defaulting nodes to wall time matches the action's no-op intent here.
  -->
  <set_use_sim_time if="$(var use_sim_time)" value="$(var use_sim_time)"/>

  <let name="robot_description"
    value="$(command 'xacro $(find-pkg-share description)/urdf/robot.urdf.xacro')"/>

  <!--
    `type="str"` short-circuits launch_xml's default YAML parse of the
    value attribute. Without it, an XML comment like
    `RS03 caps: 60 Nm, 50 rad/s` inside the URDF trips
    `yaml.safe_load() failed: mapping values are not allowed here`
    because the colon-space looks like a YAML mapping key. See
    ros2/launch#729.
  -->
  <node pkg="robot_state_publisher" exec="robot_state_publisher" output="screen">
    <param name="robot_description" type="str" value="$(var robot_description)"/>
  </node>

  <node pkg="joint_state_publisher" exec="joint_state_publisher" output="screen"/>
</launch>
